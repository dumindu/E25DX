&lt;li&gt;
&lt;p&gt;Add &lt;code&gt;content/en/page/about/index.md&lt;/code&gt; for about page&lt;/p&gt;



&lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-markdown" data-lang="markdown"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;---
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;title: About
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;url: &amp;#34;about&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;---
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;About/ Any Markdown&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;Add any image of png (or jpg) for &lt;code&gt;content/en/page/about/cover.png&lt;/code&gt; for about page cover image&lt;/p&gt;
&lt;/li&gt;
&lt;/ol&gt;</description></item><item><title>Create a New Project</title><link>https://dumindu.github.io/E25DX/docs/create-a-new-project/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dumindu.github.io/E25DX/docs/create-a-new-project/</guid><description>&lt;div class="code-window highlight"&gt;
 
	&lt;div class="code-header"&gt;
		&lt;div class="traffic-lights"&gt;
